# ============================================================
# CSFC Auth Service — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Server ───────────────────────────────────────────────────
# Render and Railway inject PORT automatically; no need to set this.
PORT=8081

# ── Database (SQL Server) ────────────────────────────────────
# Use an external SQL Server (Azure SQL, Railway, etc.)
# Example Azure SQL:
#   jdbc:sqlserver://<server>.database.windows.net:1433;databaseName=<db>;encrypt=true;trustServerCertificate=false;hostNameInCertificate=*.database.windows.net;loginTimeout=30;
DB_URL=jdbc:sqlserver://localhost:1433;databaseName=authentication_db;encrypt=true;trustServerCertificate=true
DB_USERNAME=sa
DB_PASSWORD=Admin@12345

# ── JPA ──────────────────────────────────────────────────────
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# ── Mail (Gmail App Password recommended) ────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# ── JWT ──────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=REPLACE_WITH_A_STRONG_BASE64_SECRET
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# ── Eureka ───────────────────────────────────────────────────
# If you don't have a Eureka server, set EUREKA_REGISTER=false
EUREKA_URL=http://discovery-service:8761/eureka/
EUREKA_REGISTER=true
EUREKA_FETCH=true
